pipeline {
    agent any

    tools {
        nodejs 'node24'
    }

    environment {
        IMAGE_NAME = "continuum"
        IMAGE_TAG = "${BUILD_NUMBER}"

        TEST_CONTAINER = "continuum-test"
        PROD_CONTAINER = "continuum-app"

        TEST_PORT = "3001"
        PROD_PORT = "3000"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm ci'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t %IMAGE_NAME%:%IMAGE_TAG% ."
            }
        }

        stage('Run Test Container') {
            steps {
                bat '''
                docker rm -f %TEST_CONTAINER% >nul 2>nul

                docker run -d ^
                --name %TEST_CONTAINER% ^
                -p %TEST_PORT%:3000 ^
                %IMAGE_NAME%:%IMAGE_TAG%
                '''
            }
        }

        stage('Wait For App') {
            steps {
                bat '''
                powershell -Command "Start-Sleep -Seconds 10"
                '''
            }
        }

        stage('Run E2E Tests') {
            steps {
                bat '''
                set BASE_URL=http://localhost:%TEST_PORT%
                npm run test:e2e
                '''
            }
        }

        stage('Stop Test Container') {
            steps {
                bat 'docker rm -f %TEST_CONTAINER%'
            }
        }

        stage('Deploy Production Container') {
            steps {
                bat '''
                docker rm -f %PROD_CONTAINER% >nul 2>nul

                docker run -d ^
                --name %PROD_CONTAINER% ^
                -p %PROD_PORT%:3000 ^
                %IMAGE_NAME%:%IMAGE_TAG%
                '''
            }
        }

        stage('Reload Nginx') {
            steps {
                bat '''
                if exist "C:\\nginx\\nginx.exe" (
                    "C:\\nginx\\nginx.exe" -p "C:\\nginx" -s reload
                ) else (
                    echo Nginx not installed
                )
                '''
            }
        }
    }

    post {

        always {
            bat 'docker rm -f %TEST_CONTAINER% >nul 2>nul'
        }

        success {
            echo "Pipeline completed successfully"
        }

        failure {
            echo "Pipeline failed"
        }

    }
}