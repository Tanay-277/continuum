pipeline {
    agent any

    tools {
        nodejs 'node24'
    }

    environment {
        IMAGE_NAME = "continuum"
        IMAGE_TAG = "${BUILD_NUMBER}"

        TEST_CONTAINER = "continuum-test"
        PROD_CONTAINER = "continuum-app"

        TEST_PORT = "3001"
        PROD_PORT = "3000"

        NEXT_PUBLIC_API_URL = "http://localhost:3000"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Generate Runtime Env') {
            steps {
                withCredentials([
                    string(credentialsId: 'continuum-rawg-api-key', variable: 'RAWG_API_KEY'),
                    string(credentialsId: 'continuum-client-id', variable: 'CLIENT_ID'),
                    string(credentialsId: 'continuum-client-secret', variable: 'CLIENT_SECRET'),
                    string(credentialsId: 'continuum-access-token', variable: 'ACCESS_TOKEN')
                ]) {
                    bat '''
                        echo Creating .env.local

                        echo NEXT_PUBLIC_RAWG_API_KEY=%RAWG_API_KEY%> .env.local
                        echo CLIENT_ID=%CLIENT_ID%>> .env.local
                        echo CLIENT_SECRET=%CLIENT_SECRET%>> .env.local
                        echo ACCESS_TOKEN=%ACCESS_TOKEN%>> .env.local
                        echo NEXT_PUBLIC_API_URL=%NEXT_PUBLIC_API_URL%>> .env.local
                        echo NODE_ENV=production>> .env.local

                        echo .env.local created
                        type .env.local
                    '''
                }
            }
        }

        stage('Verify Env File') {
            steps {
                bat '''
                    if not exist .env.local (
                        echo ERROR: .env.local not found
                        exit /b 1
                    )
                    echo .env.local verified
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm ci'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat '''
                    docker build -t %IMAGE_NAME%:%IMAGE_TAG% -t %IMAGE_NAME%:latest .
                '''
            }
        }

        stage('Start Test Container') {
            steps {
                bat '''
                    docker rm -f %TEST_CONTAINER% >nul 2>nul

                    docker run -d ^
                    --name %TEST_CONTAINER% ^
                    --env-file .env.local ^
                    -p %TEST_PORT%:3000 ^
                    %IMAGE_NAME%:%IMAGE_TAG%
                '''
            }
        }

        stage('Wait For App') {
            steps {
                bat '''
                    powershell -Command "for ($i=0; $i -lt 30; $i++) { try { $r = Invoke-WebRequest http://localhost:%TEST_PORT% -UseBasicParsing; if ($r.StatusCode -gt 0) { exit 0 } } catch {}; Start-Sleep 2 }; exit 1"
                '''
            }
        }

        stage('Run E2E Tests') {
            steps {
                bat '''
                    set BASE_URL=http://localhost:%TEST_PORT%
                    npm run test:e2e
                '''
            }
        }

        stage('Stop Test Container') {
            steps {
                bat '''
                    docker rm -f %TEST_CONTAINER% >nul 2>nul
                '''
            }
        }

        stage('Deploy Production') {
            steps {
                bat '''
                    docker rm -f %PROD_CONTAINER% >nul 2>nul

                    docker run -d ^
                    --name %PROD_CONTAINER% ^
                    --restart unless-stopped ^
                    --env-file .env.local ^
                    -p %PROD_PORT%:3000 ^
                    %IMAGE_NAME%:%IMAGE_TAG%
                '''
            }
        }

        stage('Reload Nginx') {
            steps {
                bat '''
                    if exist "C:\\nginx\\nginx.exe" (
                        "C:\\nginx\\nginx.exe" -p "C:\\nginx" -s reload
                    ) else (
                        echo Nginx not installed
                    )
                '''
            }
        }
    }

    post {
        always {
            bat 'docker rm -f %TEST_CONTAINER% >nul 2>nul'
        }

        success {
            echo "CI/CD SUCCESS"
        }

        failure {
            bat '''
                docker logs %TEST_CONTAINER% >nul 2>nul && docker logs %TEST_CONTAINER%
                docker logs %PROD_CONTAINER% >nul 2>nul && docker logs %PROD_CONTAINER%
            '''
        }
    }
}