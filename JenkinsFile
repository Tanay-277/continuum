pipeline {
    agent any

    // Optional, used for host-side E2E test runner.
    tools {
        nodejs 'node24'
    }

    environment {
        IMAGE_NAME = "continuum"
        IMAGE_TAG = "${BUILD_NUMBER}"
        TEST_CONTAINER = "continuum-test"
        PROD_CONTAINER = "continuum-app"
        TEST_PORT = "3001"
        PROD_PORT = "3000"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Node') {
            steps {
                bat '''
                    node -v
                    npm -v
                '''
            }
        }

        stage('Verify Docker') {
            steps {
                bat '''
                    docker --version
                    docker compose version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm ci'
            }
        }

        stage('Validate Runtime Env') {
            steps {
                bat '''
                    if not exist .env.local (
                        echo ".env.local not found in workspace. Provide runtime secrets before deploy."
                        exit /b 1
                    )
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat '''
                    docker build -f Dockerfile -t %IMAGE_NAME%:%IMAGE_TAG% -t %IMAGE_NAME%:latest .
                '''
            }
        }

        stage('Start Test Container') {
            steps {
                bat '''
                    docker rm -f %TEST_CONTAINER% >nul 2>nul
                    docker run -d --name %TEST_CONTAINER% --env-file .env.local -e NODE_ENV=production -p %TEST_PORT%:3000 %IMAGE_NAME%:%IMAGE_TAG% || exit /b 1
                '''
            }
        }

        stage('Wait For Test App') {
            steps {
                bat '''
                    powershell -NoProfile -ExecutionPolicy Bypass -Command "for ($i=0; $i -lt 30; $i++) { try { $r = Invoke-WebRequest -Uri 'http://localhost:%TEST_PORT%' -UseBasicParsing -TimeoutSec 2; if ($r.StatusCode -ge 200 -and $r.StatusCode -lt 500) { Write-Host 'App is reachable'; exit 0 } } catch {}; Start-Sleep -Seconds 2 }; Write-Error 'Test app did not become ready in time'; exit 1"
                '''
            }
        }

        stage('Run E2E Tests') {
            steps {
                bat '''
                    set BASE_URL=http://localhost:%TEST_PORT%
                    npm run test:e2e || exit /b 1
                '''
            }
        }

        stage('Stop Test Container') {
            steps {
                bat '''
                    docker rm -f %TEST_CONTAINER% >nul 2>nul
                '''
            }
        }

        stage('Deploy Production Container') {
            steps {
                bat '''
                    docker rm -f %PROD_CONTAINER% >nul 2>nul
                    docker run -d --name %PROD_CONTAINER% --restart unless-stopped --env-file .env.local -e NODE_ENV=production -p %PROD_PORT%:3000 %IMAGE_NAME%:%IMAGE_TAG% || exit /b 1
                '''
            }
        }

        stage('Reload Nginx') {
            steps {
                bat '''
                    if exist "C:\\nginx\\nginx.exe" (
                        "C:\\nginx\\nginx.exe" -p "C:\\nginx" -s reload
                    ) else (
                        echo "Nginx not found on agent. Skipping reload."
                    )
                '''
            }
        }
    }

    post {
        always {
            bat '''
                docker rm -f %TEST_CONTAINER% >nul 2>nul
            '''
        }

        success {
            echo 'CI/CD Pipeline Successful: Docker Build + E2E + Deploy'
        }

        failure {
            bat '''
                docker logs %TEST_CONTAINER% >nul 2>nul && docker logs %TEST_CONTAINER%
                docker logs %PROD_CONTAINER% >nul 2>nul && docker logs %PROD_CONTAINER%
            '''
            echo 'CI/CD Pipeline Failed'
        }
    }
}
